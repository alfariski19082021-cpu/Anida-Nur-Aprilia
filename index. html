<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <title>Yuk Belajar Bareng 💙💖</title>
  <style>
    body {
      margin: 0;
      font-family: 'Poppins', sans-serif;
      text-align: center;
      background: linear-gradient(135deg, #ffc0cb, #87cefa);
      overflow: hidden;
    }

    h1 {
      margin-top: 80px;
      color: #fff;
      text-shadow: 2px 2px 5px rgba(0,0,0,0.2);
    }

    .container {
      margin-top: 50px;
      position: relative;
    }

    button {
      padding: 12px 25px;
      margin: 10px;
      font-size: 18px;
      border: none;
      border-radius: 20px;
      cursor: pointer;
      transition: 0.3s;
    }

    #yesBtn {
      background-color: #ff69b4;
      color: white;
    }

    #yesBtn:hover {
      background-color: #ff1493;
    }

    #noBtn {
      background-color: #87cefa;
      color: white;
      position: absolute;
    }

    #message {
      margin-top: 30px;
      font-size: 20px;
      color: white;
      font-weight: bold;
    }

    /* Sticker lucu */
    .sticker {
      position: absolute;
      font-size: 40px;
      animation: float 4s infinite ease-in-out;
    }

    .s1 { top: 10%; left: 10%; }
    .s2 { top: 20%; right: 15%; }
    .s3 { bottom: 10%; left: 20%; }
    .s4 { bottom: 15%; right: 10%; }

    @keyframes float {
      0% { transform: translateY(0px); }
      50% { transform: translateY(-15px); }
      100% { transform: translateY(0px); }
    }
  </style>
</head>
<body>

  <h1>Yuk Belajar Bareng! 📚💖</h1>

  <div class="container">
    <button id="yesBtn">Mau 😊</button>
    <button id="noBtn">Tidak 😜</button>
    <div id="message"></div>
  </div>

  <!-- Sticker -->
  <div class="sticker s1">💖</div>
  <div class="sticker s2">💙</div>
  <div class="sticker s3">📚</div>
  <div class="sticker s4">✨</div>

  <script>
    const yesBtn = document.getElementById("yesBtn");
    const noBtn = document.getElementById("noBtn");
    const message = document.getElementById("message");

    yesBtn.addEventListener("click", function() {
      message.innerHTML = "Yeay! Semangat belajar ya! Kamu pasti bisa 💪📚✨";
    });

    noBtn.addEventListener("mouseover", function() {
      const x = Math.random() * (window.innerWidth - 100);
      const y = Math.random() * (window.innerHeight - 100);

      noBtn.style.left = x + "px";
      noBtn.style.top = y + "px";
    });
  </script>

</body>
</html>
